{
  "name": "isecnet-backend",
  "version": "1.0.0",
  "description": "iSecNet NHI Security Platform — Backend API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts --ext ts",
    "start": "tsx src/index.ts",
    "build": "npx prisma generate --schema=prisma/schema.prod.prisma",
    "start:prod": "npx prisma db push --schema=prisma/schema.prod.prisma && tsx src/index.ts",
    "db:migrate": "prisma migrate dev --name init",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "nodemon": "^3.1.7",
    "typescript": "^5.6.3"
  }
}
